{
  "family": "lolfront",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::291256530255:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "lolfront",
      "image": "291256530255.dkr.ecr.us-east-1.amazonaws.com/lolfront:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 80,
          "hostPort": 80,
          "protocol": "tcp"
        }
      ]
    }
  ]
}
